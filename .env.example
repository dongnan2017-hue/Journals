# Copy to .env and fill in real values. Never commit .env.

# Password you use to write entries.
WRITER_PASSWORD=change-me-writer

# Password you will one day give your daughter so she can read.
READER_PASSWORD=change-me-reader

# Long random string. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Where entries are stored on disk. Leave blank to use ../entries relative to server.
# In production (Fly.io) this is overridden to /data/entries.
ENTRIES_DIR=

# Port to listen on.
PORT=3000
